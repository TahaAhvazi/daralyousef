# Local development
APP_ENV=development
DEBUG=true
SECRET_KEY=please-change-me-to-a-long-random-string-in-production
DATABASE_URL=sqlite+aiosqlite:///./atelier.db
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_MINUTES=43200

# CORS — set your deployed frontend URL on the API server if needed:
# FRONTEND_ORIGIN=https://daralyousif.iq
# Or list origins explicitly (merged with built-in defaults):
# CORS_ORIGINS=["http://localhost:5173","https://your-app.vercel.app"]
# Disable regex matching only if you rely on an explicit CORS_ORIGINS list:
# CORS_ORIGIN_REGEX=none

# Web Push (Chrome / Edge on Windows). Optional — keys auto-generate to .vapid.json in dev.
# Generate with: python -c "from app.services.push_service import get_vapid_keys; print(get_vapid_keys())"
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:noreply@daralyousif.iq

# ── Daftra (previous ERP — pull sync into Atelier) ───────────────────────────
# Docs: https://docs.daftara.dev/
# Required on the LIVE server so Settings → Daftra Sync works after deploy:
# DAFTRA_ENABLED=true
# DAFTRA_BASE_URL=https://yousifabd1996aa.daftra.com/api2
# DAFTRA_API_KEY=your-api-key
# DAFTRA_CLIENT_ID=
# DAFTRA_CLIENT_SECRET=
# Default portal password for customers imported from Daftra (phone login)
# PORTAL_DEFAULT_PASSWORD=yousef123

# ── Production deploy checklist ──────────────────────────────────────────────
# 1) APP_ENV=production
# 2) DEBUG=false
# 3) SECRET_KEY=<long-random-string>
# 4) DATABASE_URL= same file/host as the current live site (do NOT wipe it)
#    - SQLite example: sqlite+aiosqlite:////var/www/atelier/atelier.db
#    - Postgres example: postgresql+asyncpg://user:pass@host/db
# 5) Set DAFTRA_* as above
# 6) Restart the API process — on boot it auto:
#      create_all (new tables) + additive column migrations (daftra_id, etc.)
# 7) Login as superuser → Settings → Daftra → Sync
#    Sync is pull-only and upserts by daftra_id; it does not drop existing rows.

# ── Vercel (Project → Settings → Environment Variables) ─────────────────────
# SECRET_KEY=<long-random-string>   (required in production)
# Do NOT set DATABASE_URL to ./atelier.db — on Vercel the app auto-uses /tmp.
# For persistent data use a hosted DB, e.g.:
# DATABASE_URL=postgresql+asyncpg://user:pass@host/db
# VAPID_PUBLIC_KEY / VAPID_PRIVATE_KEY required for push on serverless (no .vapid.json persist)
