# Local development
APP_ENV=development
DEBUG=true
SECRET_KEY=please-change-me-to-a-long-random-string-in-production
DATABASE_URL=sqlite+aiosqlite:///./atelier.db
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_MINUTES=43200

# CORS — set your deployed frontend URL on the API server if needed:
# FRONTEND_ORIGIN=https://daralyousif.iq
# Or list origins explicitly (merged with built-in defaults):
# CORS_ORIGINS=["http://localhost:5173","https://your-app.vercel.app"]
# Disable regex matching only if you rely on an explicit CORS_ORIGINS list:
# CORS_ORIGIN_REGEX=none

# ── Vercel (Project → Settings → Environment Variables) ─────────────────────
# SECRET_KEY=<long-random-string>   (required in production)
# Do NOT set DATABASE_URL to ./atelier.db — on Vercel the app auto-uses /tmp.
# For persistent data use a hosted DB, e.g.:
# DATABASE_URL=postgresql+asyncpg://user:pass@host/db
